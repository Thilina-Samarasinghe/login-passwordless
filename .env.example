# Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&channel_binding=require"

# Email credentials (SMTP — e.g. Brevo, Gmail App Password)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-smtp-app-password
EMAIL_FROM=your-email@example.com

# App base URL
BASE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# JWT secrets — use long, random strings in production (min 32 chars recommended)
ACCESS_TOKEN_SECRET=replace-with-a-long-random-access-secret
REFRESH_TOKEN_SECRET=replace-with-a-long-random-refresh-secret
